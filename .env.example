# Supabase Configuration
# Copy this file to .env and fill in your actual values

# Supabase Project URL
# Get this from: Project Settings > API > Project URL
SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase Anonymous Key (Public)
# Get this from: Project Settings > API > Project API keys > anon public
# Safe to use in client-side code (mobile app, web dashboard)
SUPABASE_ANON_KEY=your-anon-key-here

# Supabase Service Role Key (Secret)
# Get this from: Project Settings > API > Project API keys > service_role secret
# NEVER expose this in client-side code - use only in backend/server code
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# JWT Secret (for custom auth if needed)
# Get this from: Project Settings > API > JWT Settings > JWT Secret
SUPABASE_JWT_SECRET=your-jwt-secret-here

# Database Connection String (for direct database access if needed)
# Get this from: Project Settings > Database > Connection string > URI
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.your-project-ref.supabase.co:5432/postgres

# Storage Configuration
STORAGE_BUCKET_NAME=attendance-photos

# Application Configuration
NODE_ENV=development
PORT=3000

# Password Requirements
PASSWORD_MIN_LENGTH=8
PASSWORD_REQUIRE_UPPERCASE=true
PASSWORD_REQUIRE_LOWERCASE=true
PASSWORD_REQUIRE_NUMBER=true

# Photo Upload Limits
MAX_PHOTO_SIZE_MB=5
ALLOWED_PHOTO_TYPES=image/jpeg,image/jpg,image/png

# Rate Limiting (for authentication)
LOGIN_RATE_LIMIT_ATTEMPTS=5
LOGIN_RATE_LIMIT_WINDOW_MINUTES=15
